# Copy this to .env and fill in real values. Never commit .env.

# Google Ads API
GOOGLE_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_CLIENT_ID=your_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_LOGIN_CUSTOMER_ID=your_mcc_id_here   # MCC ID, no dashes

# Meta Marketing API
META_ACCESS_TOKEN=your_system_user_token_here

# Dashboard
STATICRYPT_PASSWORD=your_dashboard_password_here
